{
  "name": "animate-editor-sb",
  "version": "1.0.0",
  "type": "module",
  "main": ".vite/build/main/main.cjs",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "electron:dev": "concurrently -k \"nuxt dev --port 3100\" \"wait-on http://localhost:3100 && electron-forge start\"",
    "electron:build": "NUXT_APP_BASE_URL=./ nuxt generate && electron-forge build",
    "electron:make": "NUXT_APP_BASE_URL=./ nuxt generate && electron-forge make"
  },
