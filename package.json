    "@electron-forge/shared-types": "^7.11.1",
    "@iconify-json/tabler": "^1.2.35",
    "@types/wicg-file-system-access": "^2023.10.7",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "tw-animate-css": "^1.4.0",
