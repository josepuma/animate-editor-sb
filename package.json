    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "esbuild-wasm": "^0.27.4",
    "lucide-vue-next": "^1.0.0",
    "monaco-editor": "^0.55.1",
    "nuxt": "^4.4.2",
    "pixi.js": "^8.17.1",
    "reka-ui": "^2.9.2",
    "shadcn-nuxt": "^2.4.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vaul-vue": "^0.4.1",
